# === Active Broker ===
ACTIVE_BROKER=alpaca_paper

# === Alpaca Broker ===
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# === Tastytrade Broker ===
TASTYTRADE_USERNAME=your_tastytrade_username
TASTYTRADE_PASSWORD=your_tastytrade_password
TASTYTRADE_ACCOUNT=your_tastytrade_account_number

# === Schwab Broker ===
SCHWAB_API_KEY=your_schwab_api_key
SCHWAB_SECRET=your_schwab_secret
SCHWAB_ACCOUNT=your_schwab_account_hash
SCHWAB_CALLBACK_URL=https://127.0.0.1

# === Binance Broker (Crypto) ===
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# === Kraken Broker (Crypto) ===
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET=your_kraken_private_key

# === Coinbase Broker (Crypto) ===
COINBASE_API_KEY=your_coinbase_api_key
COINBASE_SECRET=your_coinbase_secret

# === Groq LLM ===
GROQ_API_KEY=gsk_your_groq_key
LLM_MODEL=llama-3.3-70b-versatile

# === Budget ===
MAX_BUDGET=10000
MAX_POSITION_PCT=20
TRAILING_STOP_PCT=2.0

# === Tax ===
TAX_RATE=0.25

# === Webhook Security ===
WEBHOOK_SECRET=your_tradingview_webhook_secret

# === Database ===
DATABASE_PATH=./data/trading.db

# === Sentiment Thresholds ===
SENTIMENT_MIN_SCORE=4
SENTIMENT_EMERGENCY_SCORE=2
NEWS_CACHE_TTL=120

# === Heartbeat ===
HEARTBEAT_INTERVAL_MINUTES=5

# === Server ===
HOST=0.0.0.0
PORT=8000

# === ATR Trailing Stop ===
# Stop distance = ATR_14 × multiplier (default: 2.0)
ATR_STOP_MULTIPLIER=2.0
# Minimum stop distance as % of entry price (floor, default: 1.5%)
ATR_STOP_MIN_PCT=1.5
# Maximum stop distance as % of entry price (ceiling, default: 8.0%)
ATR_STOP_MAX_PCT=8.0
# ATR look-back period in days (default: 14)
ATR_STOP_PERIOD=14

# === Correlation Filter ===
# Block new trade if |Pearson r| with any open position >= this (default: 0.8)
CORRELATION_THRESHOLD=0.8
# Days of price history used to compute correlation (default: 60)
CORRELATION_LOOKBACK_DAYS=60
# Minimum observations required for a reliable estimate (default: 30)
CORRELATION_MIN_PERIODS=30
# Cache TTL in seconds — correlation is re-computed at most every 30 min (default: 1800)
CORRELATION_CACHE_TTL=1800

# === Iceberg Orders (TWAP execution) ===
# Trigger iceberg when qty >= this many shares (default: 50)
ICEBERG_THRESHOLD_SHARES=50
# OR when notional >= this amount in USD (default: $2,000)
ICEBERG_THRESHOLD_USD=2000
# Shares per child order slice (default: 10)
ICEBERG_SLICE_SHARES=10
# Seconds between slices (default: 30)
ICEBERG_INTERVAL_SEC=30
# Random jitter ±% on interval (default: 0.3 = ±30%)
ICEBERG_JITTER_PCT=0.3
# Max number of slices, safety cap (default: 20)
ICEBERG_MAX_SLICES=20

# === Trading Hours Guard ===
TRADING_HOURS_ENABLED=true
# true  = trade only during high-liquidity windows (09:30-11:00 + 14:30-16:00 ET)
# false = trade full NYSE session (09:30-16:00 ET)
TRADING_HIGH_LIQUIDITY_ONLY=true
# Minutes before FOMC announcement to stop trading (default: 30)
TRADING_FOMC_BLACKOUT_MIN=30
# Minutes after FOMC announcement to resume trading (default: 60)
TRADING_FOMC_POSTBLACKOUT_MIN=60
